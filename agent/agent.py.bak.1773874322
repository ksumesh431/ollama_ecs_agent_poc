import asyncio
import json
import os
import sys
import readline
import ollama
from mcp import ClientSession
from mcp.client.streamable_http import streamablehttp_client
from rich.console import Console
from rich.markdown import Markdown
from rich.live import Live

OLLAMA_HOST = "http://localhost:11434"
OLLAMA_MODEL = "qwen3.5:27b"
CUSTOM_MCP_URL = "http://localhost:8000/mcp"

# Debug flag:
#   AWS_AGENT_DEBUG=1 -> verbose mode
#   unset / 0         -> clean mode
DEBUG = os.environ.get("AWS_AGENT_DEBUG", "0").strip().lower() in {"1", "true", "yes", "on"}

# Initialize Rich Console
console = Console()

SYSTEM_PROMPT = """You are an AWS infrastructure expert.

HIGHEST PRIORITY INSTRUCTIONS:
- Answer only the user's exact request. Do not broaden the scope.
- Do not provide root-cause analysis, recommendations, remediation steps, or best-practice advice unless the user explicitly asks for them.
- NEVER claim a scaling policy type, target tracking policy, step scaling policy, cooldown, warm-up period, metric source, threshold, or configuration value unless a tool explicitly returned that information.
- If the available tool output does not explicitly confirm something, say that you cannot confirm it from the available data.
- Do not guess, imply, or invent hidden AWS configuration.
- If the user asks for logs, metrics, target-group health history, or any other data that the available tools cannot fetch, explicitly say that those logs/data are not available through the current toolset.
- Do not substitute a different investigation just because it is related. If the requested data cannot be fetched, say so plainly.
- If the request is ambiguous, ask a short clarification question instead of guessing.

TOOL USAGE RULES:
1. If the user asks for ECS cluster instance counts, prefer get_cluster_capacity_summary.
2. If the user asks to scale an ECS service up or down, use update_ecs_service_desired_count.
3. If the service name is unclear, use list_ecs_services first.
4. If the user asks about the last deregistration on an ECS service, use get_ecs_service_recent_events first and report the last deregistration-like event visible in ECS service events.
5. If the user also asks for logs, then use get_cloudwatch_logs_for_ecs_service around the relevant event timestamp when possible.
6. When the user explicitly requests a desired count change for an ECS service, perform it without asking for confirmation, then report the previous desired count, new desired count, running count, and pending count.
7. Do not claim ALB or NLB historical target health data exists unless a tool explicitly returned it.

CRITICAL INSTRUCTIONS:
1. If you need to know a service name, use list_ecs_services first, then get_ecs_service_details.
2. NEVER output an empty response.
3. When you have the data, ALWAYS write a clear, human-readable summary as your final answer.
4. Base your answer on observed tool output. Do not present inferences as confirmed facts.
5. Keep answers tightly scoped to the user's question.
"""


async def run_chat():
    console.print("\n[bold cyan]Initializing AWS Agent...[/bold cyan]")

    async with streamablehttp_client(CUSTOM_MCP_URL) as (read, write, _):
        async with ClientSession(read, write) as session:
            await session.initialize()

            tools_result = await session.list_tools()
            ollama_tools = [
                {
                    "type": "function",
                    "function": {
                        "name": t.name,
                        "description": t.description,
                        "parameters": t.inputSchema,
                    },
                }
                for t in tools_result.tools
            ]

            if DEBUG:
                console.print(
                    f"[bold cyan]📦 Loaded {len(ollama_tools)} AWS tools. Ready to chat! (Type 'exit' to quit) [DEBUG][/bold cyan]\n"
                )
            else:
                console.print(
                    f"[bold cyan]📦 Loaded {len(ollama_tools)} AWS tools. Ready to chat! (Type 'exit' to quit)[/bold cyan]\n"
                )

            messages = [{"role": "system", "content": SYSTEM_PROMPT}]
            client = ollama.Client(host=OLLAMA_HOST)

            while True:
                try:
                    console.print("\n[bold green]👤 You:[/bold green] ", end="")
                    user_input = input().strip()
                except (KeyboardInterrupt, EOFError):
                    console.print("\n[dim]Exiting...[/dim]")
                    break

                if user_input.lower() in ["exit", "quit", "q"]:
                    console.print("[dim]Goodbye![/dim]")
                    break
                if not user_input:
                    continue

                messages.append({"role": "user", "content": user_input})

                status = None
                if not DEBUG:
                    status = console.status("[dim]Thinking...[/dim]", spinner="dots")
                    status.start()

                while True:
                    stream = client.chat(
                        model=OLLAMA_MODEL,
                        messages=messages,
                        tools=ollama_tools,
                        stream=True
                    )

                    assistant_msg = {"role": "assistant", "content": ""}

                    in_thinking = False
                    in_content = False
                    content_buffer = ""

                    for chunk in stream:
                        msg = chunk.get("message", {})

                        # 1. Handle live thinking stream (debug mode only)
                        think_piece = msg.get("thinking") or ""
                        if DEBUG and think_piece:
                            if not in_thinking:
                                console.print("\n[dim]💭 Thinking...[/dim]")
                                in_thinking = True
                            sys.stdout.write(f"\033[90m{think_piece}\033[0m")
                            sys.stdout.flush()

                        # 2. Handle live answer stream
                        content_piece = msg.get("content") or ""
                        if content_piece:
                            if status is not None:
                                status.stop()
                                status = None

                            if DEBUG and in_thinking:
                                sys.stdout.write("\n\n")
                                sys.stdout.flush()
                                console.print("[bold cyan]🤖 Agent:[/bold cyan]")
                                in_thinking = False
                            elif not DEBUG and not in_content:
                                console.print("[bold cyan]🤖 Agent:[/bold cyan]")

                            if not in_content:
                                in_content = True
                                live_render = Live(console=console, refresh_per_second=15)
                                live_render.start()

                            content_buffer += content_piece
                            assistant_msg["content"] += content_piece
                            live_render.update(Markdown(content_buffer))

                        # 3. Handle tool calls
                        if msg.get("tool_calls"):
                            assistant_msg["tool_calls"] = msg["tool_calls"]

                    if in_content:
                        live_render.stop()

                    messages.append(assistant_msg)

                    # Tool logic handling (Premature stop fix)
                    if not assistant_msg.get("tool_calls"):
                        if not assistant_msg["content"].strip():
                            if DEBUG:
                                console.print("[yellow]⚠️ Model output empty string. Forcing it to summarize...[/yellow]")
                            messages.append({
                                "role": "user",
                                "content": "You stopped without answering. Provide a brief final answer that is strictly limited to the user's exact request and only the available tool output. Do not add recommendations, root-cause analysis, or unsupported claims."
                            })
                            continue
                        else:
                            break

                    # Execute requested tools
                    for tool_call in assistant_msg["tool_calls"]:
                        fn = tool_call["function"]
                        name = fn["name"]
                        args = fn.get("arguments", {})

                        if isinstance(args, str):
                            try:
                                args = json.loads(args)
                            except json.JSONDecodeError:
                                args = {}

                        if DEBUG:
                            console.print(f"\n[bold yellow]🔧 Executing Tool :[/bold yellow] [yellow]{name}[/yellow]")
                            console.print(f"[yellow]   Arguments      : {json.dumps(args)}[/yellow]")

                        try:
                            result = await session.call_tool(name, args)
                            tool_output = result.content[0].text if result.content else "No result."
                            if DEBUG:
                                console.print(f"[bold green]   ✓ Response     :[/bold green] [green]{len(tool_output)} chars[/green]")
                        except Exception as e:
                            tool_output = f"Error: {str(e)}"
                            if DEBUG:
                                console.print(f"[bold red]   ❌ Error       :[/bold red] [red]{tool_output}[/red]")

                        messages.append({
                            "role": "tool",
                            "content": tool_output,
                        })

                if status is not None:
                    status.stop()


if __name__ == "__main__":
    asyncio.run(run_chat())
